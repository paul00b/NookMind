VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_GOOGLE_BOOKS_API_KEY=your_google_books_api_key
VITE_TMDB_API_KEY=key

# Web Push Notifications
# Generate VAPID keys with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key   # exposed to frontend
VAPID_PRIVATE_KEY=your_vapid_private_key      # server-side only
VAPID_CONTACT=mailto:your@email.com           # server-side only

# Supabase service role (server-side only, never prefix with VITE_)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Vercel cron authentication (generate a random string)
CRON_SECRET=your_random_secret

# Native Google Sign-In (Capacitor — read at build time, baked into native apps)
# Both come from Google Cloud Console -> Credentials. Web client is shared with Supabase.
VITE_GOOGLE_AUTH_WEB_CLIENT_ID=your_web_oauth_client_id.apps.googleusercontent.com
VITE_GOOGLE_AUTH_IOS_CLIENT_ID=your_ios_oauth_client_id.apps.googleusercontent.com
# Reversed iOS client ID — used in iOS Info.plist URL scheme. Format: com.googleusercontent.apps.<digits>-<hash>
VITE_GOOGLE_AUTH_IOS_REVERSED_CLIENT_ID=com.googleusercontent.apps.your_ios_client
